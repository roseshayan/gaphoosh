APP_NAME="گپ‌هوش"
APP_URL="http://gaphoosh.test"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE="Asia/Tehran"

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gaphoosh
DB_USERNAME=root
DB_PASSWORD=

DAHL_BASE_URL="https://inference.dahl.global/v1"
DAHL_TOKEN_URL="https://inference.dahl.global/tokens"

# پیشنهاد برای تست Laragon: auto
# در حالت auto، پروژه خودش از POST /tokens یک Bearer token می‌گیرد و در storage/cache ذخیره می‌کند.
# اگر token واقعی داری، DAHL_AUTH_MODE=static و DAHL_API_KEY را پر کن.
DAHL_AUTH_MODE=auto
DAHL_API_KEY=""
DAHL_AUTO_TOKEN_ON_AUTH_ERROR=true
DAHL_AUTO_TOKEN_TTL_SECONDS=604800
DAHL_DEFAULT_MODEL="MiniMaxAI/MiniMax-M2.7"
DAHL_STREAM_FALLBACK=true

MAX_DAILY_MESSAGES=80
MAX_INPUT_CHARS=12000
HISTORY_LIMIT=24
STREAM_TIMEOUT_SECONDS=180

# اگر پر شود، setup.php این شماره را ادمین می‌کند/می‌سازد.
ADMIN_MOBILE=""
ADMIN_PASSWORD=""
FIRST_REGISTERED_USER_IS_ADMIN=true
